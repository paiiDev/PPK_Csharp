@model List<StudentResponseDto>

@{
    ViewData["Title"] = "Manage Student";
}
<h1 class="text-center">Manage Students</h1>

<table class="table">
    <thead>
        <tr>
            <th scope="col">Id</th>
            <th scope="col">Name</th>
            <th scope="col">Age</th>
        </tr>
    </thead>
    <tbody>
        @for (int i = 0; i<Model.Count; i++)
        {
            var student = Model[i];
            
            <tr>
                <th scope="row">@(i+1)</th>
                <td>@student.Name</td>
                <td>@student.Age</td>
            </tr>
        }
       
        
    </tbody>
</table>